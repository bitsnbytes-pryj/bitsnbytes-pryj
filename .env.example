# Alternative: Use HackClub Proxy (fallback option)
# HACKCLUB_PROXY_API_KEY='your-hackclub-proxy-key'

# Google Site Verification (for SEO)
GOOGLE_SITE_VERIFICATION='your-google-site-verification-code'
