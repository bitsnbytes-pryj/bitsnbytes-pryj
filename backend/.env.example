# ===========================================
# Bits&Bytes Prayagraj API - Environment Variables
# ===========================================

# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# CORS (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000,https://gobitsnbytes.org

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_REQUESTS=5

# Password Hashing
BCRYPT_ROUNDS=10

# SMTP / Email (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_APP_PASSWORD=your-app-password

# Admin Email (for notifications)
ADMIN_EMAIL=admin@bnbprayagraj.com

# Webhook API Key (for external services)
WEBHOOK_API_KEY=your-webhook-api-key-change-in-production