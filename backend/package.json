{
  "name": "bnb-prayagraj-public-api",
  "version": "1.0.0",
  "description": "Public API service for Bits&Bytes Prayagraj",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
