# OSM API Key (optional, for map features)
OSM_API_KEY='your-osm-api-key'

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL='your-supabase-project-url'
NEXT_PUBLIC_SUPABASE_ANON_KEY='your-supabase-anon-key'

# AI Configuration - Z.ai (Required for AI Assistant)
# Get your API key from: https://open.bigmodel.cn/
# The assistant will not work without this key
ZAI_API_KEY='your-zai-api-key'

# Admin Backend URL (for admin dashboard - consolidated backend)
NEXT_PUBLIC_ADMIN_API_URL='http://localhost:3000'

# Google Site Verification (for SEO)
GOOGLE_SITE_VERIFICATION='your-google-site-verification-code'
