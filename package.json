{
  "name": "bitsnbytes-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "description": "Bits&Bytes Platform Monorepo - Student tech community website",
  "scripts": {
    "build": "cd frontend && pnpm run build",
    "build:backend": "cd backend && pnpm run build",
    "build:admin": "cd admin-backend && pnpm run build",
    "build:all": "pnpm -r run build",
    "dev": "cd frontend && pnpm run dev",
    "dev:backend": "cd backend && pnpm run dev",
    "dev:admin": "cd admin-backend && pnpm run dev",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r exec rm -rf node_modules dist .next",
    "install:all": "pnpm install"
  },
  "keywords": [
    "bitsnbytes",
    "student-community",
    "tech-community",
    "monorepo"
  ],
  "author": "Bits&Bytes",
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "sharp": "^0.33.5"
    }
  }
}