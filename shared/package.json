{
  "name": "@bitsnbytes/shared",
  "version": "1.0.0",
  "description": "Shared types, schemas, and constants for Bits&Bytes platform",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "default": "./src/schemas/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "default": "./src/constants/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "bitsnbytes",
    "shared",
    "types",
    "schemas",
    "zod"
  ],
  "author": "Bits&Bytes",
  "license": "MIT",
  "peerDependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5",
    "zod": "^3.23.8"
  }
}